# ============================================================
#  MAXX-XMD WhatsApp Bot - Environment Variables
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ============================================================

# ── REQUIRED ────────────────────────────────────────────────
# Get your FREE Session ID from: https://pair.maxxtech.co.ke
SESSION_ID=MAXX-XMD~H4sI...your-session-here...

# ── BOT SETTINGS (Optional) ─────────────────────────────────
BOT_NAME=MAXX-XMD
PREFIX=.
WORK_MODE=public
OWNER_NUMBER=254712345678

# ── PAYMENTS (Optional) ─────────────────────────────────────
# Get from: https://paystack.com
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...

# ── HEROKU (Only needed for .setname/.setpic to persist on Heroku) ──
HEROKU_API_KEY=HRKU-...
HEROKU_APP_NAME=your-app-name
# MAXX-XMD

