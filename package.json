{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "heroku-prebuild": "corepack enable && corepack prepare pnpm@10.26.1 --activate",
    "heroku-postbuild": "pnpm install --no-frozen-lockfile && pnpm --filter @workspace/api-server run build",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
